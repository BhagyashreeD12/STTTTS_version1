# .env.example — copy this to .env and fill in your values
# NEVER commit the real .env to git (it's already in .gitignore)

# ── Required ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...your-key-here...

# ── Active LLM model (no code change needed to switch models) ─────────
# Options: gpt-5.4-nano | gpt-5.4-mini | gpt-5.4-pro
#          gpt-4.1-nano | gpt-4.1-mini  | gpt-4o-mini | gpt-4o
# Costs and notes are in scripts/openai_brain.py → MODEL_CONFIGS
LLM_MODEL=gpt-5.4-mini

# ── Currency conversion for cost logs ─────────────────────────────────
USD_TO_INR=84
